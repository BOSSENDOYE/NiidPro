# ── Frontend React (SPA) — rh.lamadoneadn.com ──
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Forcer HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Ne pas réécrire les fichiers/dossiers existants (assets, sw.js, manifest…)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Toutes les autres routes → index.html (history mode)
  RewriteRule ^ index.html [L]
</IfModule>
