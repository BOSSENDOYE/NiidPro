# ════════════════════════════════════════════════════════════
#  .env de PRODUCTION — apirh.lamadoneadn.com
#  Copier en « .env » sur le serveur puis remplir les valeurs ___.
# ════════════════════════════════════════════════════════════

APP_NAME="RH+PAIE"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://apirh.lamadoneadn.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

# URL du frontend (utilisée par CORS) — IMPORTANT
FRONTEND_URL=https://rh.lamadoneadn.com

# ── Base de données (créée dans cPanel › MySQL Databases) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=___nom_de_la_base___
DB_USERNAME=___utilisateur_mysql___
DB_PASSWORD=___mot_de_passe___

# ── Sessions / Sanctum ──
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_DOMAIN=.lamadoneadn.com
SANCTUM_STATEFUL_DOMAINS=rh.lamadoneadn.com,apirh.lamadoneadn.com

# ── Stockage / cache / queue ──
FILESYSTEM_DISK=public
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log

# ── Logs ──
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Email (peut aussi être configuré dans Configuration › Mailing) ──
MAIL_MAILER=smtp
MAIL_HOST=___smtp_host___
MAIL_PORT=587
MAIL_USERNAME=___smtp_user___
MAIL_PASSWORD=___smtp_pass___
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@lamadoneadn.com"
MAIL_FROM_NAME="${APP_NAME}"

BCRYPT_ROUNDS=12
